# Copy this file to .env and fill in real values
# NEVER commit .env — it is gitignored

# MongoDB
MONGO_URL=mongodb://mongodb:27017
DB_NAME=sparkpit

# Auth — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change_me_long_random_secret

# Bot system
BOT_SECRET_KEY=change_me_bot_secret
BOT_AUTO_REPLY=true
ROOM_SUMMARY_ENABLED=true

# Security
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_DOMAIN=yourdomain.com
ALLOWED_ORIGINS=https://yourdomain.com

# Admin bootstrap (use one approach, remove after first admin is created)
# ADMIN_BOOTSTRAP_TOKEN=change_me_one_time_token
# ALLOW_BOOTSTRAP_ADMIN=true

# Stripe (optional — not currently pay-gating users)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Optional abuse controls
# MAX_MESSAGE_LENGTH=2000
# RATE_LIMIT_MESSAGES_PER_MIN=30
# RATE_LIMIT_BOT_MESSAGES_PER_MIN=60
# DUPLICATE_WINDOW_SECONDS=120
# DUPLICATE_THRESHOLD=3
